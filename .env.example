# Скопируйте в .env в корне проекта (файл .env в .gitignore).
# Формат: KEY=value без пробелов вокруг =

# Опционально: каталог данных (очередь, логи). По умолчанию ./data
# HH_DATA_DIR=./data

# Каталог для persistent-профиля Chromium (относительно корня проекта или абсолютный путь)
HH_SESSION_DIR=./data/session

# Для apply.mjs: 1 — без окна (после отладки)
# HH_HEADLESS=1

# --- scan-telegram.mjs: вакансии в Telegram ---
# TELEGRAM_BOT_TOKEN=123456:ABC...
# TELEGRAM_CHAT_ID=your_chat_or_channel_id
# HH_KEYWORDS=python,backend
# HH_SCAN_LIMIT=10
# HH_PAUSE_MS=2500
# HH_AREA=1

# --- open-vacancies.mjs: ключи в config/search-keywords.txt или свой файл ---
# HH_KEYWORDS_FILE=./config/search-keywords.txt
# HH_PER_KEYWORD_LIMIT=8
# Лимит вакансий за один запуск (если задан HH_SESSION_LIMIT, он важнее HH_MAX_TOTAL)
# HH_SESSION_LIMIT=7
# HH_MAX_TOTAL=7
# Пауза между открытием вакансий, мс (случайно в диапазоне)
# HH_OPEN_DELAY_MIN_MS=3000
# HH_OPEN_DELAY_MAX_MS=5000
# Джиттер после перехода на страницу поиска, мс
# HH_SEARCH_JITTER_MIN_MS=1000
# HH_SEARCH_JITTER_MAX_MS=2000
# Короткий джиттер после загрузки карточки вакансии, мс (harvest и open-vacancies)
# HH_POST_LOAD_JITTER_MIN_MS=200
# HH_POST_LOAD_JITTER_MAX_MS=800
# После успешного harvest: первая строка config/search-keywords.txt → в конец (0 — не ротировать)
# HH_ROTATE_KEYWORD_AFTER_RUN=1
#
# Логика ключей (harvest): loop | cycles | keywords
# HH_KEYWORDS_LOGIC=cycles
# HH_KEYWORDS_CYCLES=1
# В режиме keywords — сколько первых строк из файла за один проход (пусто = весь файл)
# HH_KEYWORDS_MAX=5
#
# Рабочие часы (локальное время ОС): вне интервала — пауза без поиска/карточек
# HH_WORK_HOURS_ENABLED=0
# HH_WORK_HOUR_START=9
# HH_WORK_HOUR_END=18

# --- harvest.mjs + дашборд: LLM (Polza и/или OpenRouter, см. config/OPENROUTER.md) ---
# POLZA_API_KEY=...   (альтернативное имя того же ключа: POLZA_AI_API_KEY)
# POLZA_MODEL=openai/gpt-4o-mini
# POLZA_BASE_URL=https://polza.ai/api/v1
# LLM_PROVIDER=auto
#
# OpenRouter (если не используете Polza)
# OpenRouter_API_KEY=sk-or-v1-...
# OPENROUTER_MODEL=qwen/qwen3.6-plus-preview:free
# (или openrouter/free — маршрутизатор бесплатных моделей)
# или другой free-id, например: OPENROUTER_MODEL=google/gemma-2-9b-it:free
# OPENROUTER_ALLOW_PAID=1
# OPENROUTER_HTTP_REFERER=http://localhost

# DASHBOARD_PORT=3849
# Адрес привязки HTTP: локально 127.0.0.1; в Docker обычно 0.0.0.0 (см. docker-compose.yml)
# DASHBOARD_BIND=127.0.0.1
# По умолчанию в логах: http://127.0.0.1:PORT/ — задавайте только если нужна другая строка (например доступ с другой машины по LAN):
# DASHBOARD_LOG_URL=http://192.168.1.10:3849/
